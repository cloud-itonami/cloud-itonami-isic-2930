{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the kotoba-lang org of this workspace (transferred + renamed from
 ;; com-junkawasaki/langgraph-clj / com-junkawasaki/langchain-clj). This
 ;; repo is standalone (forkable outside the workspace); the :local/root
 ;; paths only resolve inside the monorepo checkout — a standalone fork
 ;; should override them with git coordinates.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}
        io.github.kotoba-lang/langchain-store
        {:local/root "../../kotoba-lang/langchain-store"}
        io.github.kotoba-lang/robotics
        {:local/root "../../kotoba-lang/robotics"}
        ;; REAL engineering-simulation dependency (ADR-2607152000, extending
        ;; ADR-2607151600's automotive pilot to this vertical): autoparts.
        ;; robotics now actually calls physics-2d/world-step -- a real,
        ;; tested time-stepped rigid-body impulse solver -- to run a real
        ;; weld-joint/fastener proof-load pull-test simulation, instead of
        ;; comparing static self-reported fields. Unlike automotive (which
        ;; also took a dependency on a sibling kami-engine-vehicle-designer
        ;; design-library repo), this vertical has no such sibling, so the
        ;; physics module is built directly in autoparts.robotics and the
        ;; ONLY new dependency is physics-2d itself.
        io.github.kotoba-lang/physics-2d
        {:git/url "https://github.com/kotoba-lang/physics-2d.git"
         :sha "03b6c23c8d9aa36b92a8130fd3e37fc2548b4d26"}
        ;; REAL CAD/BREP bridge (ADR-2607160000, extending ADR-2607152000/
        ;; ADR-2607151600's real-engineering-simulation pattern to this
        ;; vertical's own digital-twin pilot): autoparts.cad now actually
        ;; builds+tessellates a BREP packaging envelope for a part-lot's
        ;; test-specimen/joint coupon via org-iso-10303's brep.feature/
        ;; brep.tessellate, the SAME kernel automotive's vdesign.cad already
        ;; depends on -- not a new CAD kernel written for this actor. As
        ;; with physics-2d above, this vertical has no sibling design-
        ;; library repo, so the dependency is taken directly here rather
        ;; than through a paired repo the way automotive's
        ;; kami-engine-vehicle-designer dependency works. Deliberately NOT
        ;; added: kotoba-lang/webgpu (autoparts.scene matches its
        ;; kami.webgpu.mesh DATA shape only -- that lib is .cljs-only, real
        ;; GPU device/buffer calls, unusable in this JVM/.cljc actor repo;
        ;; see autoparts.scene's docstring for the same disclosed limitation
        ;; vdesign.scene documents).
        io.github.kotoba-lang/org-iso-10303
        {:git/url "https://github.com/kotoba-lang/org-iso-10303.git"
         :sha "a1de3b075bcdcfbfb75c781eb88e3d07195831cf"}
        ;; Cross-actor supply-chain-linkage contract (ADR-2607999950,
        ;; extended by ADR-2607999960): `autoparts.governor`
        ;; independently re-verifies an optional `:upstream-pedigree`
        ;; (a `kotoba.pedigree` record an upstream isic-2410 steel
        ;; heat issued via `steelworks.export/pedigree-for-heat`)
        ;; before accepting it as evidence a part-lot's steel
        ;; feedstock clears this actor's own acceptance floor, AND
        ;; `autoparts.export/pedigree-for-part-lot` now issues THIS
        ;; actor's own pedigree for a downstream `cloud-itonami-
        ;; isic-2910` to independently re-verify -- see that fn's
        ;; docstring for the genuine 2-hop chaining this pin bump
        ;; unlocks (`kotoba.pedigree/claim`'s `:upstream` option,
        ;; ADR-2607999960). A real pinned git-coordinate dep (not
        ;; :local/root), same reasoning as physics-2d/org-iso-10303
        ;; above. Bumped past `cloud-itonami-isic-2410`'s own
        ;; (older) pedigree pin deliberately -- this actor's OWN
        ;; export needs the `:upstream` chaining support that pin
        ;; adds; isic-2410 has no need for it (it only ISSUES
        ;; single-hop pedigrees, never embeds an upstream one) so its
        ;; pin is left alone, out of this ADR's scope.
        io.github.kotoba-lang/pedigree
        {:git/url "https://github.com/kotoba-lang/pedigree.git"
         :sha "f85784211422a651fea26f448f601abfba2e7d61"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "autoparts.sim"]}
  :export {:main-opts ["-m" "autoparts.export-run"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; ADR-2607999950's critical end-to-end proof: a GENUINE cross-repo
  ;; call into cloud-itonami-isic-2410's own `steelworks.export`/
  ;; `steelworks.robotics` (a real heat -> a real physics-2d
  ;; simulation -> a real kotoba.pedigree record), fed as plain EDN
  ;; into this actor's governor. Kept out of the default :test alias
  ;; (and its own test-cross-repo/ source root) so plain `clojure
  ;; -M:dev:test` never REQUIRES a same-org sibling checkout that a
  ;; casual fork of just this repo would not have -- the same
  ;; workspace-sibling :local/root convention `io.github.kotoba-lang/
  ;; langgraph`/`robotics` above already use, one org level up
  ;; instead of across orgs. Still no live network call at runtime:
  ;; this is a build-time classpath dependency exercised by tests, the
  ;; same category as every other :local/root dep in this fleet.
  :cross-repo-test
  {:extra-paths ["test-cross-repo"]
   :extra-deps {io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                io.github.cloud-itonami/cloud-itonami-isic-2410
                {:local/root "../cloud-itonami-isic-2410"}}
   :main-opts ["-m" "cognitect.test-runner" "-d" "test-cross-repo"]
   :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test" "test-cross-repo"
                        "--fail-level" "error"]}}}
